{
  "name": "@long2x/cresh-ui",
  "version": "5.18.0",
  "description": "A Vue 3 UI library that contains a set of high quality components",
  "author": "long2x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rottenronin/cresh-ui.git"
  },
  "bugs": {
    "url": "https://github.com/rottenronin/cresh-ui/issues"
  },
  "keywords": [
    "web",
    "ui",
    "forms",
    "validations",
    "vue3"
  ],
  "files": [
    "dist",
    "dist/sass",
    "dist/default-theme.css",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/cresh-ui.cjs.js",
  "module": "./dist/cresh-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cresh-ui.es.js",
      "require": "./dist/cresh-ui.cjs.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.es.js",
      "require": "./dist/ui.cjs.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.cjs.js"
    },
    "./form-controls": {
      "types": "./dist/form-controls.d.ts",
      "import": "./dist/form-controls.es.js",
      "require": "./dist/form-controls.cjs.js"
    },
    "./directives": {
      "types": "./dist/directives.d.ts",
      "import": "./dist/directives.es.js",
      "require": "./dist/directives.cjs.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.es.js",
      "require": "./dist/helpers.cjs.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.es.js",
      "require": "./dist/plugins.cjs.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css",
      "default": "./dist/style.css"
    },
    "./default-theme.css": {
      "import": "./dist/default-theme.css",
      "require": "./dist/default-theme.css",
      "default": "./dist/default-theme.css"
    },
    "./c-notify.scss": {
      "import": "./dist/sass/c-notify.scss",
      "require": "./dist/sass/c-notify.scss",
      "default": "./dist/sass/c-notify.scss"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.js",
    "preview": "vite preview --port 5050",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "test:unit": "vitest --run",
    "test:component": "cypress run --component",
    "test": "run-s test:*",
    "postbuild": "node scripts/postbuild.js",
    "release": "changeset version && changeset publish"
  },
  "peerDependencies": {
    "vue": "^3.3.4",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.2"
  },
  "dependencies": {
    "@vuepic/vue-datepicker": "^8.0.0",
    "chart.js": "^4.4.0",
    "events": "^3.3.0",
    "libphonenumber-js": "^1.11.0",
    "yup": "^1.3.0"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^5.1.0",
    "@cypress/vue": "^6.0.0",
    "@faker-js/faker": "^8.3.1",
    "@storybook/addon-docs": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/vue3-vite": "^8.6.0",
    "@types/chart.js": "^2.9.37",
    "@types/events": "^3.0.0",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/server-renderer": "^3.4.0",
    "@vue/test-utils": "^2.4.2",
    "@vue/tsconfig": "^0.4.0",
    "cypress": "^13.6.0",
    "eslint": "^8.57.0",
    "eslint-config-materya": "^10.0.0",
    "eslint-plugin-vue": "^9.22.0",
    "jsdom": "^23.2.0",
    "npm-run-all": "^4.1.5",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.71.0",
    "sass-loader": "^14.2.0",
    "storybook": "^8.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.2.0",
    "vue-tsc": "^1.8.0"
  },
  "homepage": "https://github.com/rottenronin/cresh-ui#readme",
  "directories": {
    "test": "tests"
  },
  "publishConfig": {
    "access": "public"
  }
}
