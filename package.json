{
  "name": "@long2x/cresh-ui",
  "version": "6.1.4",
  "description": "A Vue 3 UI library that contains a set of high quality components",
  "author": "long2x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rottenronin/cresh-ui.git"
  },
  "bugs": {
    "url": "https://github.com/rottenronin/cresh-ui/issues"
  },
  "keywords": [
    "web",
    "ui",
    "forms",
    "validations",
    "vue3"
  ],
  "files": [
    "dist",
    "dist/sass",
    "dist/default-theme.css",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/cresh-ui.cjs.js",
  "module": "./dist/cresh-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cresh-ui.es.js",
      "require": "./dist/cresh-ui.cjs.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.es.js",
      "require": "./dist/ui.cjs.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.cjs.js"
    },
    "./form-controls": {
      "types": "./dist/form-controls.d.ts",
      "import": "./dist/form-controls.es.js",
      "require": "./dist/form-controls.cjs.js"
    },
    "./directives": {
      "types": "./dist/directives.d.ts",
      "import": "./dist/directives.es.js",
      "require": "./dist/directives.cjs.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.es.js",
      "require": "./dist/helpers.cjs.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.es.js",
      "require": "./dist/plugins.cjs.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css",
      "default": "./dist/style.css"
    },
    "./default-theme.css": {
      "import": "./dist/default-theme.css",
      "require": "./dist/default-theme.css",
      "default": "./dist/default-theme.css"
    },
    "./c-notify.scss": {
      "import": "./dist/sass/c-notify.scss",
      "require": "./dist/sass/c-notify.scss",
      "default": "./dist/sass/c-notify.scss"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.cjs",
    "preview": "vite preview --port 5050",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "test:unit": "vitest --run",
    "test:component": "cypress run --component",
    "test": "run-s test:*",
    "postbuild": "node scripts/postbuild.cjs",
    "release": "changeset version && changeset publish"
  },
  "peerDependencies": {
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6"
  },
  "dependencies": {
    "@vuepic/vue-datepicker": "^12.1.0",
    "chart.js": "^4.4.0",
    "events": "^3.3.0",
    "libphonenumber-js": "^1.12.42",
    "yup": "^1.3.0"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^7.3.1",
    "@cypress/vue": "^6.0.3",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@types/chart.js": "^2.9.37",
    "@types/events": "^3.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/language-core": "^3.2.7",
    "@vue/server-renderer": "^3.5.33",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.14.2",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.15.0",
    "eslint-plugin-storybook": "10.3.6",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7"
  },
  "type": "module",
  "homepage": "https://github.com/rottenronin/cresh-ui#readme",
  "directories": {
    "test": "tests"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
